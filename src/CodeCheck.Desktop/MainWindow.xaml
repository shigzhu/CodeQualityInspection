<Window x:Class="CodeCheck.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CodeCheck.Desktop"
        mc:Ignorable="d"
        Title="CodeCheck Desktop" Height="780" Width="1100">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="220" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Vertical">
            <TextBlock Text="Workspace Directory" FontWeight="Bold" />
            <DockPanel Margin="0,4,0,8">
                <Button Content="Browse..." Width="90" DockPanel.Dock="Right" Margin="8,0,0,0" Click="BrowseWorkspaceButton_Click" />
                <TextBox x:Name="WorkspaceDirectoryTextBox" />
            </DockPanel>
            <TextBlock Text="CLI Path" FontWeight="Bold" />
            <DockPanel Margin="0,4,0,8">
                <Button Content="Browse..." Width="90" DockPanel.Dock="Right" Margin="8,0,0,0" Click="BrowseCliButton_Click" />
                <TextBox x:Name="CliPathTextBox" Text="CodeCheck.Cli.exe" />
            </DockPanel>
            <TextBlock Text="Config File" FontWeight="Bold" />
            <DockPanel Margin="0,4,0,8">
                <Button Content="Browse..." Width="90" DockPanel.Dock="Right" Margin="8,0,0,0" Click="BrowseConfigButton_Click" />
                <TextBox x:Name="ConfigFileTextBox" Text="configs/default-codecheck.json" />
            </DockPanel>
            <TextBlock Text="Status File" FontWeight="Bold" />
            <DockPanel Margin="0,4,0,8">
                <Button Content="Open" Width="90" DockPanel.Dock="Right" Margin="8,0,0,0" Click="OpenStatusFileButton_Click" />
                <TextBox x:Name="StatusFileTextBox" Text="temp/scan.status.json" />
            </DockPanel>
            <TextBlock Text="Control File" FontWeight="Bold" />
            <DockPanel Margin="0,4,0,8">
                <Button Content="Open" Width="90" DockPanel.Dock="Right" Margin="8,0,0,0" Click="OpenControlFileButton_Click" />
                <TextBox x:Name="ControlFileTextBox" Text="temp/.codecheck-control.json" />
            </DockPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="ValidateConfigButton" Content="Validate Config" Width="120" Margin="0,0,8,0" Click="ValidateConfigButton_Click" />
            <Button x:Name="StartScanButton" Content="Start Scan" Width="100" Margin="0,0,8,0" Click="StartScanButton_Click" />
            <Button Content="Stop Process" Width="110" Margin="0,0,8,0" Click="StopProcessButton_Click" />
            <Button Content="Refresh" Width="90" Margin="0,0,8,0" Click="RefreshButton_Click" />
            <Button Content="Pause" Width="90" Margin="0,0,8,0" Click="PauseButton_Click" />
            <Button Content="Resume" Width="90" Margin="0,0,8,0" Click="ResumeButton_Click" />
            <Button Content="Cancel" Width="90" Margin="0,0,8,0" Click="CancelButton_Click" />
            <Button Content="Clear Control" Width="110" Margin="0,0,8,0" Click="ClearControlButton_Click" />
            <Button Content="Open Report" Width="110" Margin="0,0,8,0" Click="OpenReportButton_Click" />
            <Button Content="Open Folder" Width="110" Margin="0,0,8,0" Click="OpenReportFolderButton_Click" />
            <Button Content="Clear Output" Width="110" Click="ClearOutputButton_Click" />
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Status:" FontWeight="Bold" Margin="0,0,8,4" />
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="StatusTextBlock" Margin="0,0,16,4" />
            <TextBlock Grid.Row="0" Grid.Column="2" Text="Phase:" FontWeight="Bold" Margin="0,0,8,4" />
            <TextBlock Grid.Row="0" Grid.Column="3" x:Name="PhaseTextBlock" Margin="0,0,0,4" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Engine:" FontWeight="Bold" Margin="0,0,8,4" />
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="EngineTextBlock" Margin="0,0,16,4" />
            <TextBlock Grid.Row="1" Grid.Column="2" Text="Updated:" FontWeight="Bold" Margin="0,0,8,4" />
            <TextBlock Grid.Row="1" Grid.Column="3" x:Name="UpdatedAtTextBlock" Margin="0,0,0,4" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Files:" FontWeight="Bold" Margin="0,0,8,4" />
            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TotalFilesTextBlock" Margin="0,0,16,4" />
            <TextBlock Grid.Row="2" Grid.Column="2" Text="Issues / Failed:" FontWeight="Bold" Margin="0,0,8,4" />
            <TextBlock Grid.Row="2" Grid.Column="3" x:Name="IssueStatsTextBlock" Margin="0,0,0,4" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Report:" FontWeight="Bold" Margin="0,0,8,4" />
            <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" x:Name="ReportPathTextBlock" TextWrapping="Wrap" Margin="0,0,0,4" />
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Score:" FontWeight="Bold" Margin="0,0,8,4" />
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="ScoreTextBlock" Margin="0,0,16,4" />
            <TextBlock Grid.Row="0" Grid.Column="2" Text="Level:" FontWeight="Bold" Margin="0,0,8,4" />
            <TextBlock Grid.Row="0" Grid.Column="3" x:Name="LevelTextBlock" Margin="0,0,16,4" />
            <TextBlock Grid.Row="0" Grid.Column="4" Text="Active Issues:" FontWeight="Bold" Margin="0,0,8,4" />
            <TextBlock Grid.Row="0" Grid.Column="5" x:Name="ActiveIssuesTextBlock" Margin="0,0,0,4" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="New:" FontWeight="Bold" Margin="0,0,8,4" />
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="NewIssuesTextBlock" Margin="0,0,16,4" />
            <TextBlock Grid.Row="1" Grid.Column="2" Text="Existing:" FontWeight="Bold" Margin="0,0,8,4" />
            <TextBlock Grid.Row="1" Grid.Column="3" x:Name="ExistingIssuesTextBlock" Margin="0,0,16,4" />
            <TextBlock Grid.Row="1" Grid.Column="4" Text="Fixed:" FontWeight="Bold" Margin="0,0,8,4" />
            <TextBlock Grid.Row="1" Grid.Column="5" x:Name="FixedIssuesTextBlock" Margin="0,0,0,4" />
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Severity" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox x:Name="SeverityFilterComboBox" Width="130" Margin="0,0,16,0" SelectionChanged="IssueFilter_Changed" SelectedIndex="0">
                <ComboBoxItem Content="All" />
                <ComboBoxItem Content="Blocker" />
                <ComboBoxItem Content="Critical" />
                <ComboBoxItem Content="Warning" />
                <ComboBoxItem Content="Suggestion" />
            </ComboBox>
            <TextBlock Text="Keyword" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox x:Name="IssueKeywordTextBox" Width="260" Margin="0,0,8,0" TextChanged="IssueFilter_Changed" />
            <Button Content="Clear Filter" Width="110" Click="ClearIssueFilterButton_Click" />
        </StackPanel>

        <DataGrid Grid.Row="5" x:Name="IssuesDataGrid" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,0,12" MouseDoubleClick="IssuesDataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="90" />
                <DataGridTextColumn Header="Rule" Binding="{Binding RuleId}" Width="140" />
                <DataGridTextColumn Header="File" Binding="{Binding File}" Width="220" />
                <DataGridTextColumn Header="Line" Binding="{Binding Line}" Width="70" />
                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="6" Text="Output" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBox Grid.Row="7" x:Name="MessageTextBox" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
    </Grid>
</Window>
